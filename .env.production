# ── Production environment variables ─────────────────────────────────────────
# Fill in the real values before deploying.
# DO NOT commit this file with real secrets — use your CI/CD secrets manager.

# Base URL of the deployed NestJS backend (no trailing slash)
VITE_LOCAL_TEMU_BASE_URL=https://api.your-domain.com/api
VITE_AUTH_API_BASE_URL=https://api.your-domain.com/api/v1/auth

# eBay OAuth initiation endpoint (DataCube external service)
VITE_EBAY_AUTH_URL=https://api.help-on-time.com/api/datacube/public/ebayauth

# Legacy datacube base (used by old API slice — keep until fully migrated)
VITE_BASE_API_KEY=https://api.help-on-time.com/api/datacube
